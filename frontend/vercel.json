{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "frontend/api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "handle": "filesystem" },                 
    { "src": "/api/(.*)", "dest": "frontend/api/$1.js" },
    { "src": "/(.*)", "dest": "/index.html" }  
}
