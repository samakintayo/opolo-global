{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/initiate-payment", "dest": "/api/index.js" },
    { "src": "/api/verify-payment/(.*)", "dest": "/api/index.js" },
    { "src": "/api/check-payment/(.*)", "dest": "/api/index.js" },
    { "src": "/api/webhook/payment", "dest": "/api/index.js" }
  ]
}
